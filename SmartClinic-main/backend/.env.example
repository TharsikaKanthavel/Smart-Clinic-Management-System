PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/smartclinic
JWT_SECRET=smartclinic_access_secret_change_me
JWT_REFRESH_SECRET=smartclinic_refresh_secret_change_me
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
RATE_LIMIT_PER_MINUTE=200

# SMTP (required for OTP emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="SmartClinic <your-email@gmail.com>"
